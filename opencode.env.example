# Copy this file to opencode.env and fill values locally.
# opencode.env is ignored by git.
OPENCODE_PROVIDER_ID=ctf
OPENCODE_PROVIDER_NAME=CTF Model Gateway
OPENCODE_PROVIDER_NPM=@ai-sdk/openai-compatible
OPENCODE_BASE_URL=https://your-model-gateway.example/v1
OPENCODE_API_KEY=replace-with-your-key
OPENCODE_MODEL=gpt-5.2
OPENCODE_TIMEOUT_SECONDS=180
# Go调度层会自动保证任务超时至少为OPENCODE_TIMEOUT_SECONDS+60。
# 需要更长解题时间时再显式调大。
# CTF_AGENT_TASK_TIMEOUT=300
# Optional password for the OpenCode Web server. Recommended on shared servers.
# OPENCODE_SERVER_PASSWORD=replace-with-a-strong-password

# Docker images selected by challenge type.
CTF_AGENT_DOCKER_IMAGE=ctf-agent-opencode:latest
CTF_AGENT_IMAGE_WEB=ctf-agent-web:latest
CTF_AGENT_IMAGE_PWN=ctf-agent-pwn:latest
CTF_AGENT_IMAGE_CRYPTO=ctf-agent-crypto:latest
CTF_AGENT_IMAGE_REVERSE=ctf-agent-reverse:latest
CTF_AGENT_IMAGE_FORENSICS=ctf-agent-forensics:latest
CTF_AGENT_IMAGE_MISC=ctf-agent-misc:latest

# OpenCode Web exposure for each running task container.
CTF_AGENT_OPENCODE_WEB_ENABLED=true
CTF_AGENT_OPENCODE_BIND_IP=127.0.0.1
CTF_AGENT_OPENCODE_PUBLIC_BASE_URL=http://127.0.0.1
